# Copie para .env e preencha (o .env fica fora do git).
# Connection string do Postgres do Supabase:
#   Supabase Dashboard -> Project Settings -> Database -> Connection string (URI) -> aba "Session pooler"
# Substitua [YOUR-PASSWORD] pela senha do banco.
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
